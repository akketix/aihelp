{
  "name": "mneurix-wiki",
  "region": "fra",
  "features": [
    "buildpack-stack=ubuntu-22"
  ],
  "ingress": {
    "rules": [
      {
        "component": {
          "name": "wiki"
        },
        "match": {
          "path": {
            "prefix": "/"
          }
        }
      }
    ]
  },
  "services": [
    {
      "name": "wiki",
      "github": {
        "repo": "akketix/aihelp",
        "branch": "master",
        "deploy_on_push": true
      },
      "build_command": "npm install && npm run build",
      "run_command": "node dist/server/entry.mjs",
      "environment_slug": "node-js",
      "envs": [
        {
          "key": "PORT",
          "scope": "RUN_AND_BUILD_TIME",
          "value": "8080"
        },
        {
          "key": "HOST",
          "scope": "RUN_AND_BUILD_TIME",
          "value": "0.0.0.0"
        }
      ],
      "http_port": 8080,
      "instance_count": 1,
      "instance_size_slug": "basic-xxs"
    }
  ]
}
